# Copy to .env and fill in. Never commit .env.
#
# Bearer を有効にする（公開前・Dify 連携の推奨）:
#   ./scripts/generate-bearer-token.sh   # ランダムトークンを表示
#   その値を GA4MCP_BEARER_TOKEN に設定。Dify の MCP ヘッダー Authorization: Bearer <同じ値>

# --- Server ---
GA4MCP_PORT=8080
GA4MCP_LOG_LEVEL=INFO
# development | staging | production
GA4MCP_ENV=development

# --- MCP client auth (Dify / n8n の Bearer) ---
# 本番・インターネット公開前は bearer を推奨。ローカルだけの手早い試験は none でも可。
GA4MCP_AUTH_MODE=bearer
# bearer のとき必須（空のままではサーバーは起動しません）
GA4MCP_BEARER_TOKEN=
# Dify で誤トークン時に OAuth メタデータ探索に入りにくくする（推奨）
GA4MCP_BEARER_FAILURE_HTTP_STATUS=403
# GA4MCP_AUTH_MODE=none

# --- GA4 property allowlist ---
# GA4MCP_ALLOWED_PROPERTY_IDS=123456789,987654321
# GA4MCP_ALLOW_ALL_PROPERTIES=false

# --- Guardrails ---
# GA4MCP_MAX_DATE_RANGE_DAYS=366
# GA4MCP_MAX_ROW_LIMIT=100000
# GA4MCP_MAX_CONCURRENT_PER_PROPERTY=4
# GA4MCP_ENABLE_REALTIME=true
# GA4MCP_RETURN_PROPERTY_QUOTA=false
# GA4MCP_REQUEST_TIMEOUT_MS=60000

# --- Streamable HTTP / DNS リバインディング (本番では必須) ---
# GA4MCP_ENABLE_DNS_REBINDING_PROTECTION=true
# GA4MCP_ALLOWED_HOSTS=your.domain.example,localhost:8080
# GA4MCP_ALLOWED_ORIGINS=https://your.domain.example

# リバースプロキシ配下で X-Forwarded-For を信頼するホップ数 (0=信頼しない)
# GA4MCP_TRUSTED_PROXY_HOPS=1

# JSON のみ応答 (SSE ではなく)。クライアントに合わせて調整
# GA4MCP_JSON_RESPONSE=false

# --- Google ADC ---
# サービスアカウント JSON のパス (ローカル・コンテナでよく使う)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/sa.json
